<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base style — required for dot-notation children -->
    <style name="TextAppearance.ExpenseIQ" parent="TextAppearance.Material3.BodyMedium"/>

    <style name="TextAppearance.ExpenseIQ.DisplayLarge">
        <item name="android:textSize">57sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.ExpenseIQ.HeadlineLarge">
        <item name="android:textSize">32sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="TextAppearance.ExpenseIQ.HeadlineMedium">
        <item name="android:textSize">28sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="TextAppearance.ExpenseIQ.TitleLarge">
        <item name="android:textSize">22sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="TextAppearance.ExpenseIQ.TitleMedium">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="TextAppearance.ExpenseIQ.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.03</item>
    </style>

    <style name="TextAppearance.ExpenseIQ.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="TextAppearance.ExpenseIQ.LabelLarge">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="TextAppearance.ExpenseIQ.AmountLarge">
        <item name="android:textSize">40sp</item>
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/primary</item>
    </style>

</resources>